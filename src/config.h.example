// Configuration template - copy this to config.h and update with your actual values
#define NODE_ID "your-buoy-id"
#define NAME "Your Buoy Name"
#define FIRMWARE_VERSION "1.1.1"
#define GPS_SYNC_INTERVAL_SECONDS (24 * 3600)  // 24 hours

// API Configuration
#define API_SERVER "your-api-server.com"
#define API_PORT 80
#define API_ENDPOINT "/upload"
#define API_KEY "your-api-key-here"

// OTA Configuration
#define OTA_SERVER "your-ota-server.com"
#define OTA_PATH ""

// Network Configuration
#define NETWORK_PROVIDER "your-network-provider"

// DNS Configuration (optional). Enable to override network-provided DNS.
// Set USE_CUSTOM_DNS to 1 to use the servers below; set back to 0 to revert.
#define USE_CUSTOM_DNS 0
#define DNS_PRIMARY "1.1.1.1"
#define DNS_SECONDARY "8.8.8.8"

// Time Configuration
#define NTP_SERVER "pool.ntp.org"
#define TIMEZONE "UTC0"

// Power/ADC calibration

// Critical battery guard (device enters deep sleep when battery drops below threshold)
#define ENABLE_CRITICAL_GUARD 1
#define BATTERY_CRITICAL_PERCENT 25          // deep sleep at or below this percent
#define BATTERY_CRITICAL_VOLTAGE 3.70f       // deep sleep at or below this voltage (V)

// Modem timing and shutdown feature flags
// ENABLE_GENTLE_MODEM_TIMING: use conservative timing for modem power-on/off sequences
#define ENABLE_GENTLE_MODEM_TIMING 1
// ENABLE_CPOWD_SHUTDOWN: try AT+CPOWD=1 graceful shutdown before hard power-off
#define ENABLE_CPOWD_SHUTDOWN 1

// Optional SIM PIN (leave empty string if not required)
#define SIM_PIN ""

// Debug: set to 1 to stay awake instead of entering deep sleep (useful for serial monitoring)
#define DEBUG_NO_DEEP_SLEEP 0
